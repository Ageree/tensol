# Sthrip/Tensol backend — environment template
#
# Copy to `.env` and replace placeholders. NEVER commit `.env`.
# Current execution rail: GCP Compute Engine for ephemeral scan VMs.

# === Core ===
TENSOL_DB_URL=file:./data/tensol.db
PORT=3000
NODE_ENV=development

# 64-byte hex; signs the audit chain and per-VM legacy scan-progress callbacks.
TENSOL_AUDIT_SIGNING_KEY=replace_with_64_byte_hex
# 64-byte hex; signs local session cookies.
TENSOL_SESSION_COOKIE_SECRET=replace_with_64_byte_hex

# === Auth (Clerk) ===
# Server-only Clerk secret. Never expose this in the site bundle.
CLERK_SECRET_KEY=replace_with_clerk_secret_key
# Optional comma-separated frontend origins accepted as Clerk authorized parties.
CLERK_AUTHORIZED_PARTIES=http://127.0.0.1:5175,https://sthrip.dev,https://www.sthrip.dev

# === Public callback URL ===
# MUST be public HTTPS and reachable from GCP scan VMs. For local live smoke,
# run a tunnel (for example cloudflared) to the backend and put that URL here.
TENSOL_WEBHOOK_BASE_URL=https://api.sthrip.dev
# Shared secret for inbound V2 webhook signature validation (vps-agent -> backend).
TENSOL_WEBHOOK_SECRET=replace_with_32_byte_hex

# === Legacy Hetzner config gate ===
# Required by server/src/config.ts at boot even though the active scan rail is GCP.
# Placeholder strings are acceptable when Hetzner is not used.
HETZNER_API_TOKEN=unused-on-gcp-but-required-by-config
HETZNER_SSH_KEY_NAME=unused-on-gcp-but-required-by-config

# === GCP Compute Engine ===
GOOGLE_APPLICATION_CREDENTIALS=.gcp/tensol-vm-spawner.json
GCP_PROJECT_ID=tensol-scanners
GCP_ZONE=europe-west1-b
GCP_MACHINE_TYPE=e2-small
GCP_BOOT_DISK_IMAGE=projects/debian-cloud/global/images/family/debian-12
GCP_BOOT_DISK_SIZE_GB=30
GCP_NETWORK_NAME=default
GCP_SUBNET_NAME=default
GCP_SSH_PUBLIC_KEY=
GCP_AGENT_FIREWALL_ENSURE=true
GCP_AGENT_FIREWALL_NAME=allow-tensol-agent-8080
GCP_AGENT_FIREWALL_PORT=8080
GCP_AGENT_FIREWALL_SOURCE_RANGES=0.0.0.0/0

# === Per-scan worker images ===
# Must be pullable by a fresh GCP VM. Private GHCR images will make live scans fail.
TENSOL_VPS_AGENT_IMAGE=ghcr.io/ageree/tensol-vps-agent:002-blackbox-mvp-latest
DECEPTICON_IMAGE=ghcr.io/purpleailab/decepticon-langgraph:latest

# === Auth (Telegram) ===
# Bot token from @BotFather. Shape: <bot_id>:<35-char base64ish>
TENSOL_TELEGRAM_BOT_TOKEN=7**********:AAH**********
# Operator chat_id (numeric) — receives Deep-inquiry handoffs
TENSOL_TELEGRAM_CHAT_ID=000000000
# Bot @-handle WITHOUT leading @ — used to compose t.me/<username>?start=<token>
TENSOL_TELEGRAM_BOT_USERNAME=tensol_leadsbot
# 32-byte hex; passed to Telegram setWebhook --secret_token + validated
# against X-Telegram-Bot-Api-Secret-Token header on POST /v1/webhooks/telegram-update
TENSOL_TELEGRAM_WEBHOOK_SECRET=replace_with_32_byte_hex
# Local dev: use long-polling instead of webhook (no public URL needed)
TENSOL_TELEGRAM_LONGPOLL=false

# === Object storage ===
# Evidence artifacts, scan logs, and report PDFs.
# Current rule: production is GCP-first and Google Cloud Storage is not used.
# Configure explicit GCS-compatible storage (for example GCS HMAC +
# https://storage.googleapis.com) or implement a native GCS adapter before
# treating evidence/PDF/report jobs as production-ready.
TENSOL_EVIDENCE_BUCKET=tensol-evidence-prod
TENSOL_EVIDENCE_PREFIX=scans/
AWS_ACCESS_KEY_ID=replace_with_access_key
AWS_SECRET_ACCESS_KEY=replace_with_secret_key
AWS_ENDPOINT_URL=https://storage.googleapis.com
AWS_REGION=auto

# === Decepticon / review LLM ===
TENSOL_OPENROUTER_API_KEY=replace_with_sk_or_v1_key
TENSOL_REVIEW_LLM_API_KEY=
TENSOL_REVIEW_LLM_BASE_URL=https://openrouter.ai/api/v1
TENSOL_REVIEW_LLM_MODEL=qwen/qwen3.7-max
TENSOL_LITELLM_MASTER_KEY=sk-tensol-litellm-internal
TENSOL_POSTGRES_PASSWORD=tensol-postgres-internal
TENSOL_NEO4J_PASSWORD=tensol-neo4j-internal

# === GitHub App (PR reviews) ===
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_SLUG=

# === Operator allow-list ===
# Comma-separated list of email addresses authorised to access /v1/admin/*
# routes (Deep-inquiry triage, etc.). Compared case-insensitively against
# the authenticated user's email. Empty (default) = no operators configured,
# every /v1/admin/* request from any user returns 403.
TENSOL_OPERATOR_EMAILS=op1@tensol.com,op2@tensol.com

# === Dev ===
# Bypass DNS ownership proof in local/dev only. Does not relax private/loopback
# target rejection; live smoke still needs a public target you control.
TENSOL_DEV_DNS_BYPASS=false

# Legacy compatibility flag; keep false unless explicitly testing old billing paths.
TENSOL_YOOKASSA_LIVE=false
