{
  "name": "cyberstrike-hybrid",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*",
    "tests/lab/xss-fixture",
    "tests/lab/auth-fixture",
    "tests/lab/spa-fixture"
  ],
  "scripts": {
    "bun:assert-version": "bun scripts/assert-bun-version.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc -b",
    "test": "bun test",
    "test:coverage": "bun test --coverage && bun run coverage:gate",
    "coverage:gate": "bun scripts/coverage-gate.ts --threshold=0.80",
    "build": "tsc -b",
    "db:migrate:up": "bun packages/db/scripts/migrate.ts",
    "db:migrate:rollback": "bun packages/db/scripts/rollback.ts",
    "db:migrate:redo": "bun packages/db/scripts/redo.ts",
    "db:migrate:check": "bun packages/db/scripts/migrate-check.ts",
    "lab:xss": "bun tests/lab/xss-fixture/bin/run.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/bun": "^1.1.13",
    "@types/pg": "8.11.10",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@cyberstrike/api": "workspace:*",
    "@cyberstrike/browser-auth": "workspace:*",
    "@cyberstrike/browser-driver": "workspace:*",
    "@cyberstrike/lab-auth-fixture": "workspace:*",
    "@cyberstrike/audit": "workspace:*",
    "@cyberstrike/authz": "workspace:*",
    "@cyberstrike/browser-worker": "workspace:*",
    "@cyberstrike/contracts": "workspace:*",
    "@cyberstrike/coordinator": "workspace:*",
    "@cyberstrike/db": "workspace:*",
    "@cyberstrike/decepticon-adapter": "workspace:*",
    "@cyberstrike/lab-xss-fixture": "workspace:*",
    "@cyberstrike/object-storage": "workspace:*",
    "@cyberstrike/queue": "workspace:*",
    "@cyberstrike/scope-engine": "workspace:*",
    "@cyberstrike/report-builder": "workspace:*",
    "@cyberstrike/reports": "workspace:*",
    "@cyberstrike/validator-worker": "workspace:*",
    "@cyberstrike/validators": "workspace:*",
    "kysely": "0.27.4",
    "pg": "8.13.1",
    "zod": "^3.23.8"
  }
}
