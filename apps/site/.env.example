# ─────────────────────────────────────────────────────────────────────
# Tensol — site (apps/site/.env.local)
# ─────────────────────────────────────────────────────────────────────
# Backend API base URL. Leave EMPTY in dev — Vite proxies /api/* to the
# local Bun backend on :3000 (see vite.config.ts). Only set this for
# cross-origin deployments where the frontend is hosted separately from
# the API. Consumed by `apps/site/src/lib/api.ts`.
VITE_API_BASE_URL=http://localhost:3000

# URL of the Telegram-relay /api/contact endpoint (the script in
# scripts/telegram-relay.ts). Leave unset in dev to force the t.me
# deep-link fallback.
VITE_CONTACT_ENDPOINT=https://relay.tensol.dev/api/contact

# Telegram bot @handle without the @ — used for the t.me deep-link
# fallback when the endpoint is unset or unreachable.
VITE_CONTACT_TELEGRAM_HANDLE=tensol_lead_bot

# Final fallback — mailto: address shown in the error panel.
VITE_CONTACT_MAILTO=nikto256@gmail.com


# ─────────────────────────────────────────────────────────────────────
# Tensol — Telegram relay (apps/site/scripts/.env, gitignored)
# Loaded by scripts/telegram-relay.ts. NEVER commit real values.
# ─────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:abc-paste-bot-token-here
TELEGRAM_CHAT_ID=-1001234567890
PORT=8787
ALLOWED_ORIGIN=https://tensol.dev,http://localhost:5175
