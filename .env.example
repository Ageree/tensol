# Sample environment for local development.
# Copy to .env (NOT committed) and adjust as needed.
# In APP_ENV=local, every key below is optional and falls back to defaults.
# In APP_ENV in {dev|staging|production|internal-lab}, every key is required and boot fails fast.

APP_ENV=local

# Postgres (matches infra/docker/docker-compose.local.yml).
DATABASE_URL=postgres://cs:cs@localhost:5433/cyberstrike

# MinIO (matches infra/docker/docker-compose.local.yml).
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=csadmin
OBJECT_STORAGE_SECRET_KEY=cs-secret-local-only
OBJECT_STORAGE_BUCKET=cs-local

QUEUE_ADAPTER=local
DECEPTICON_ADAPTER=fake

# Must be at least 32 characters in non-local environments.
SESSION_SECRET=local-development-session-secret-not-for-prod

# Optional.
# SENTRY_DSN=
