# Sthrip production Caddyfile.
#
# Caddy auto-provisions Let's Encrypt certificates for hostnames on
# first boot (port 80 + 443 must be reachable from the public internet, which
# the GCP firewall rule allow-sthrip-api-web allows for api.sthrip.dev).
#
# Sites:
#   api.sthrip.dev -> reverse-proxy to 127.0.0.1:3000 (Bun server)
#
# The apex frontend currently remains on Vercel; do not point sthrip.dev at
# this VM unless the frontend deployment plan changes.
#
# Place at /etc/caddy/Caddyfile and run `caddy reload` (or restart the
# systemd unit).

{
	email ops@sthrip.dev
	# Uncomment to bring up the staging CA instead of production while testing:
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory

	# Disable the admin endpoint on the public interface.
	admin off
}

# ---- Apex + www redirect to canonical apex ----
www.sthrip.dev {
	redir https://sthrip.dev{uri} permanent
}

# ---- Marketing + authenticated dashboard SPA (apex) ----
sthrip.dev {
	root * /opt/tensol/site-dist
	encode gzip zstd

	# SPA fallback — any non-file URL serves index.html so React Router
	# handles the route client-side.
	try_files {path} /index.html
	file_server

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options    "nosniff"
		X-Frame-Options           "SAMEORIGIN"
		Referrer-Policy           "strict-origin-when-cross-origin"
		Permissions-Policy        "geolocation=(), microphone=(), camera=()"
	}

	# Cache hashed Vite assets aggressively; never cache index.html.
	@hashed path_regexp ^/assets/.+\.[0-9a-f]{8,}\..+$
	header @hashed Cache-Control "public, max-age=31536000, immutable"
	@html        path /
	@htmlIndex   path /index.html
	header @html      Cache-Control "no-cache"
	header @htmlIndex Cache-Control "no-cache"
}

# ---- API + webhooks ----
api.sthrip.dev {
	encode gzip zstd

	reverse_proxy 127.0.0.1:3000 {
		header_up Host              {host}
		header_up X-Real-IP         {remote_host}
		header_up X-Forwarded-For   {remote_host}
		header_up X-Forwarded-Proto {scheme}

		# vps-agent webhook callbacks can be large (signed audit payload +
		# evidence index). 5 minutes is generous; the server itself caps the
		# request body well below this.
		transport http {
			read_timeout  300s
			write_timeout 300s
		}
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options    "nosniff"
		Referrer-Policy           "no-referrer"
	}

	# Health probe for uptime monitors (Caddy short-circuits this without
	# round-tripping through the upstream).
	respond /caddy-health 200 {
		body "ok"
		close
	}
}
