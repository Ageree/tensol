# Sthrip/Tensol production environment template.
#
# Copy this file to /opt/tensol/.env.prod on the production VM and fill every
# placeholder. The server fails fast on missing required vars at boot — see
# server/src/config.ts (Zod schema). Generate hex secrets with:
#
#   openssl rand -hex 64   # 64-byte audit / session keys
#   openssl rand -hex 32   # 32-byte webhook / telegram secrets
#
# NEVER commit the filled file. /opt/tensol/.env.prod must be chmod 600 and
# owned by root (or the docker daemon's user).

# ============================================================
#  Core runtime
# ============================================================
NODE_ENV=production
PORT=3000

# SQLite database file inside the container. The /app/server/data directory
# is bind-mounted from /opt/tensol/data on the host (see docker-compose).
TENSOL_DB_URL=file:./data/tensol.db

# 64-byte hex — signs the audit-log HMAC chain.
# Generate: openssl rand -hex 64
TENSOL_AUDIT_SIGNING_KEY=REPLACE_ME_64_HEX_BYTES

# 64-byte hex — signs session cookies.
# Generate: openssl rand -hex 64
TENSOL_SESSION_COOKIE_SECRET=REPLACE_ME_64_HEX_BYTES

# ============================================================
#  Auth (Clerk)
# ============================================================
# Server-only live Clerk secret. Must belong to the same Clerk instance as
# VITE_CLERK_PUBLISHABLE_KEY on Vercel. If this is unset or still sk_test while
# the site uses pk_live, authenticated dashboard API calls return 401
# unauthenticated even when the user is signed in.
CLERK_SECRET_KEY=REPLACE_ME_CLERK_SECRET_KEY

# Comma-separated frontend origins accepted as Clerk token authorized parties.
CLERK_AUTHORIZED_PARTIES=https://sthrip.dev,https://www.sthrip.dev

# 32-byte hex — shared with vps-agent for HMAC-SHA256 webhook signatures on
# POST /v1/webhooks/scan-complete.
# Generate: openssl rand -hex 32
TENSOL_WEBHOOK_SECRET=REPLACE_ME_32_HEX_BYTES

# Public base URL where the server receives webhooks from VPS agents. MUST be
# https and reachable from GCP scan VMs. For local live smoke, use a public
# tunnel to this backend and set the tunnel URL here before launching a scan.
TENSOL_WEBHOOK_BASE_URL=https://api.sthrip.dev

# ============================================================
#  Email (Resend)
# ============================================================
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_REPLACE_ME

# ============================================================
#  Telegram bot (operator notifications + leads)
# ============================================================
TENSOL_TELEGRAM_BOT_TOKEN=REPLACE_ME_FROM_BOTFATHER
TENSOL_TELEGRAM_CHAT_ID=REPLACE_ME_NUMERIC_CHAT_ID
TENSOL_TELEGRAM_BOT_USERNAME=tensol_leadsbot
# Optional secret token Telegram echoes on webhook POSTs (set via setWebhook).
TENSOL_TELEGRAM_WEBHOOK_SECRET=REPLACE_ME_32_HEX_BYTES

# ============================================================
#  Hetzner (LEGACY — required by config.ts even on the GCP rail
#  because the schema still expects these vars; they drive nothing
#  at runtime when GCP is used, but the boot validator refuses to
#  start without them).
#  Safe to set to placeholder strings.
# ============================================================
HETZNER_API_TOKEN=unused-on-gcp-but-required-by-config
HETZNER_SSH_KEY_NAME=unused-on-gcp-but-required-by-config

# ============================================================
#  GCP Compute Engine — per-scan VM lifecycle (real provider).
# ============================================================
GOOGLE_APPLICATION_CREDENTIALS=/opt/tensol/secrets/tensol-vm-spawner.json
GCP_PROJECT_ID=tensol-scanners
GCP_ZONE=europe-west1-b
GCP_MACHINE_TYPE=e2-small
GCP_BOOT_DISK_IMAGE=projects/debian-cloud/global/images/family/debian-12
GCP_BOOT_DISK_SIZE_GB=30
GCP_NETWORK_NAME=default
GCP_SUBNET_NAME=default

# Optional SSH key injected into scan VMs for break-glass debugging.
# Leave empty in production if OS Login / serial-console diagnostics are used.
GCP_SSH_PUBLIC_KEY=

# The backend must reach vps-agent on :8080 after the VM boots.
GCP_AGENT_FIREWALL_ENSURE=true
GCP_AGENT_FIREWALL_NAME=allow-tensol-agent-8080
GCP_AGENT_FIREWALL_PORT=8080
GCP_AGENT_FIREWALL_SOURCE_RANGES=0.0.0.0/0

# ============================================================
#  Object storage — evidence + report PDFs
#
# Current rule: production is GCP-first and Google Cloud Storage is not used.
# Configure an explicit GCS-compatible endpoint/HMAC pair or replace this rail
# with a native GCS adapter before treating evidence/PDF/report jobs as ready.
# Leaving these unset makes the server boot, but render_pdf,
# send_scan_complete_telegram, and scan evidence uploads fail when invoked.
# ============================================================
TENSOL_EVIDENCE_BUCKET=tensol-evidence-prod
TENSOL_EVIDENCE_PREFIX=scans/
AWS_ACCESS_KEY_ID=REPLACE_ME_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_ME_SECRET_KEY
AWS_ENDPOINT_URL=https://storage.googleapis.com
AWS_REGION=auto

# ============================================================
#  Billing
# ============================================================
# Exposed by /v1/config/feature-flags so the site can show the OxaPay paid path.
TENSOL_BILLING_PROVIDER=oxapay
# Legacy pre-pivot compatibility flag. Keep false unless explicitly testing
# old YooKassa-only behavior.
TENSOL_YOOKASSA_LIVE=false

# ============================================================
#  Operator allow-list (comma-separated) — gates /v1/admin/*
# ============================================================
TENSOL_OPERATOR_EMAILS=ops@sthrip.dev,admin@sthrip.dev

# ============================================================
#  Per-scan worker images (pulled by VM cloud-init)
# ============================================================
# vps-agent image — published from this repo's vps-agent/Dockerfile.
# Must be pullable by a fresh GCP VM. A private GHCR package causes live scans
# to fail during startup before the agent binds :8080.
TENSOL_VPS_AGENT_IMAGE=ghcr.io/ageree/tensol-vps-agent:002-blackbox-mvp-latest

# Decepticon image value is pulled explicitly by cloud-init for prefetching;
# the embedded compose also pulls ghcr.io/purpleailab/decepticon-* services.
# Mirror those images if upstream GHCR access is private in your environment.
DECEPTICON_IMAGE=ghcr.io/purpleailab/decepticon-langgraph:latest

# ============================================================
#  T128 Bug #7 — Decepticon LiteLLM secrets propagated to VM
# ============================================================
# OpenRouter API key — REQUIRED. The embedded LiteLLM proxy routes
# every Decepticon model name (anthropic/claude-*, openai/gpt-*) to
# `openrouter/qwen/qwen3.7-max`. Without this set, the proxy returns
# 401 on the first agent call and the scan hangs at recon.
# Get one at https://openrouter.ai/keys.
TENSOL_OPENROUTER_API_KEY=REPLACE_ME_SK_OR_V1_KEY

# LiteLLM master key — internal token between langgraph and litellm
# containers on the per-scan VM. Not a user-facing secret; any
# random ≥32-byte string is fine. Default below is safe; override
# only if you want per-deploy rotation.
TENSOL_LITELLM_MASTER_KEY=sk-tensol-litellm-internal

# Per-VM Postgres + Neo4j passwords. Internal, generated per deploy if
# you want rotation. The containers running on the spawned VM are
# loopback-only; no public exposure.
TENSOL_POSTGRES_PASSWORD=tensol-postgres-internal
TENSOL_NEO4J_PASSWORD=tensol-neo4j-internal

# ============================================================
#  Feature flags
# ============================================================
# Production YooKassa wiring (false = sandbox/mock).
TENSOL_YOOKASSA_LIVE=false

# DNS-verification bypass — MUST be false in prod.
TENSOL_DEV_DNS_BYPASS=false
