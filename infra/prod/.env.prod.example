# Tensol production environment template.
#
# Copy this file to /opt/tensol/.env.prod on the Timeweb VM and fill every
# placeholder. The server fails fast on missing required vars at boot — see
# server/src/config.ts (Zod schema). Generate hex secrets with:
#
#   openssl rand -hex 64   # 64-byte audit / session keys
#   openssl rand -hex 32   # 32-byte webhook / telegram secrets
#
# NEVER commit the filled file. /opt/tensol/.env.prod must be chmod 600 and
# owned by root (or the docker daemon's user).

# ============================================================
#  Core runtime
# ============================================================
NODE_ENV=production
PORT=3000

# SQLite database file inside the container. The /app/server/data directory
# is bind-mounted from /opt/tensol/data on the host (see docker-compose).
TENSOL_DB_URL=file:./data/tensol.db

# 64-byte hex — signs the audit-log HMAC chain.
# Generate: openssl rand -hex 64
TENSOL_AUDIT_SIGNING_KEY=REPLACE_ME_64_HEX_BYTES

# 64-byte hex — signs session cookies.
# Generate: openssl rand -hex 64
TENSOL_SESSION_COOKIE_SECRET=REPLACE_ME_64_HEX_BYTES

# 32-byte hex — shared with vps-agent for HMAC-SHA256 webhook signatures on
# POST /v1/webhooks/scan-complete.
# Generate: openssl rand -hex 32
TENSOL_WEBHOOK_SECRET=REPLACE_ME_32_HEX_BYTES

# Public base URL where the server receives webhooks from VPS agents. MUST be
# https and reachable from the Yandex VMs (T128 prerequisite).
TENSOL_WEBHOOK_BASE_URL=https://api.tensol.ru

# ============================================================
#  Email (Resend)
# ============================================================
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_REPLACE_ME

# ============================================================
#  Telegram bot (operator notifications + leads)
# ============================================================
TENSOL_TELEGRAM_BOT_TOKEN=REPLACE_ME_FROM_BOTFATHER
TENSOL_TELEGRAM_CHAT_ID=REPLACE_ME_NUMERIC_CHAT_ID
TENSOL_TELEGRAM_BOT_USERNAME=tensol_leadsbot
# Optional secret token Telegram echoes on webhook POSTs (set via setWebhook).
TENSOL_TELEGRAM_WEBHOOK_SECRET=REPLACE_ME_32_HEX_BYTES

# ============================================================
#  Hetzner (LEGACY — required by config.ts even on Timeweb/Yandex
#  topology because the schema still expects these vars; they
#  drive nothing at runtime when YANDEX_* is set, but the boot
#  validator refuses to start without them).
#  Safe to set to placeholder strings.
# ============================================================
HETZNER_API_TOKEN=unused-on-yandex-but-required-by-config
HETZNER_SSH_KEY_NAME=unused-on-yandex-but-required-by-config

# ============================================================
#  Yandex Cloud — per-scan VM lifecycle (real provider).
# ============================================================
# Service-account JSON key as a SINGLE-LINE compact JSON string.
# Produce with:  yc iam key create --service-account-id <id> -o key.json
# then:          jq -c . key.json
YANDEX_SA_KEY_JSON={"id":"...","service_account_id":"...","private_key":"..."}

YANDEX_PROD_FOLDER_ID=b1g62rnc9735lbms9klh
YANDEX_PROD_NETWORK_ID=REPLACE_ME_NETWORK_ID
YANDEX_PROD_SUBNET_ID=REPLACE_ME_SUBNET_ID
YANDEX_PROD_SUBNET_ZONE=ru-central1-a

# Ed25519 or RSA public key (single line, OpenSSH format).
YANDEX_PROD_SSH_PUBLIC_KEY=ssh-ed25519 AAAA... tensol@prod

# Boot disk image id for the per-scan VM (Ubuntu 24.04 family is fine).
# yc compute image get-latest-by-family --folder-id standard-images --family ubuntu-2404-lts
YANDEX_BOOT_DISK_IMAGE_ID=REPLACE_ME_IMAGE_ID

# Optional sibling folder for non-prod test runs (cleanup job sweeps both).
YANDEX_TEST_FOLDER_ID=

# ============================================================
#  Yandex Object Storage (S3-compatible) — evidence + report PDFs
# ============================================================
TENSOL_EVIDENCE_BUCKET=tensol-evidence-prod
TENSOL_EVIDENCE_PREFIX=scans/
AWS_ACCESS_KEY_ID=REPLACE_ME_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_ME_SECRET_KEY
AWS_ENDPOINT_URL=https://storage.yandexcloud.net
AWS_REGION=ru-central1

# ============================================================
#  Operator allow-list (comma-separated) — gates /v1/admin/*
# ============================================================
TENSOL_OPERATOR_EMAILS=ops@tensol.ru,admin@tensol.ru

# ============================================================
#  Per-scan worker images (pulled by VM cloud-init)
# ============================================================
# vps-agent image — published from this repo's vps-agent/Dockerfile.
TENSOL_VPS_AGENT_IMAGE=ghcr.io/ageree/tensol-vps-agent:0.1.0

# Decepticon harness image (PurpleAILAB upstream or your mirror).
DECEPTICON_IMAGE=ghcr.io/ageree/decepticon:latest

# ============================================================
#  Feature flags
# ============================================================
# Production YooKassa wiring (false = sandbox/mock).
TENSOL_YOOKASSA_LIVE=false

# DNS-verification bypass — MUST be false in prod.
TENSOL_DEV_DNS_BYPASS=false
