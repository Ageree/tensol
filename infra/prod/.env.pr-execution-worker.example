# Sthrip PR execution worker environment template.
#
# Copy this file to /opt/tensol/.env.pr-execution-worker on the production VM.
# It is intentionally separate from /opt/tensol/.env.prod so the isolated
# worker does not inherit API, Clerk, Telegram, database, or storage secrets.

# 32-byte hex shared with /opt/tensol/.env.prod:
# STHRIP_PR_EXECUTION_WORKER_SECRET must match exactly in both files.
# Generate once: openssl rand -hex 32
STHRIP_PR_EXECUTION_WORKER_SECRET=REPLACE_ME_32_HEX_BYTES

# Production uses Vercel Sandbox Firecracker microVMs. Docker is local/dev
# fallback only.
STHRIP_PR_EXECUTION_SANDBOX_PROVIDER=vercel-sandbox
STHRIP_PR_EXECUTION_VERCEL_RUNTIME=node24
STHRIP_PR_EXECUTION_VERCEL_VCPUS=2

# Optional GitHub token for private-repository fetches. The worker passes it as
# a transient Git extraheader and redacts it from returned artifacts.
STHRIP_PR_EXECUTION_GITHUB_TOKEN=

# Vercel Sandbox SDK auth for the GCP-hosted worker. This compose deployment is
# not hosted on Vercel, so fill all three explicit access-token fields.
VERCEL_TOKEN=REPLACE_ME_VERCEL_ACCESS_TOKEN
VERCEL_TEAM_ID=team_REPLACE_ME
VERCEL_PROJECT_ID=prj_REPLACE_ME
