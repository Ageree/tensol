# ─────────────────────────────────────────────────────────────────────
# Sthrip — vps-agent (per-scan ephemeral scanner VM)
# ─────────────────────────────────────────────────────────────────────
# This file documents the runtime env contract that cloud-init bakes into
# every per-scan VM the backend spawns. NEVER commit a real `.env` file —
# only this `.env.example`. Values below are SHAPE HINTS only.
#
# Source of truth: vps-agent/src/agent.ts (`readRequiredEnv`) and
# vps-agent/src/decepticon-runner.ts (`buildEnv`).
# Plan reference: specs/002-blackbox-mvp/plan.md §"vps-agent contract".

# ─── Required by vps-agent/src/agent.ts ──────────────────────────────
# HMAC sign key — 256-bit hex/base64 secret shared with the backend for this VM.
# Used to verify inbound backend -> agent POST /scan dispatches. V2 outbound
# scan-complete callbacks use TENSOL_WEBHOOK_SECRET below instead.
TENSOL_SIGN_KEY=replace-with-32-byte-hex-per-scan

# Scan ID this VM is dedicated to. Single-scan per VPS.
TENSOL_SCAN_ID=scan_01HXXXXXXXXXXXXXXXXXXXXX

# HTTP port the Hono agent binds to. Optional, defaults to 8080.
PORT=8080

# ─── Outbound V2 webhook (signed by vps-agent → backend) ─────────────
# The webhook_url is supplied per-request in the inbound POST /scan body,
# NOT via env. Documented here for operator awareness.
# TENSOL_WEBHOOK_BACKEND_URL=https://api.sthrip.dev
TENSOL_WEBHOOK_SECRET=replace-with-fleet-webhook-secret

# ─── Decepticon runtime (passed through to docker compose) ───────────
# Consumed by vps-agent/src/decepticon-runner.ts → buildEnv(). The
# target URL + profile + findings dir come from the inbound /scan
# payload at runtime; values below are baseline defaults for the image.
DECEPTICON_FINDINGS_DIR=/workspace/findings
DECEPTICON_COMPOSE_FILE=/opt/decepticon/docker-compose.yml

# ─── Evidence upload (GCS-native via VM service account) ──────────
# Bucket where vps-agent uploads HAR/screenshot/log artifacts before
# emitting the webhook. The scanner VM must expose a metadata token with
# storage.objects.create on this bucket.
TENSOL_EVIDENCE_BUCKET=tensol-evidence-prod
TENSOL_EVIDENCE_PREFIX=evidence/

# ─── PR runtime execution worker (/pr-execution) ────────────────────
# Shared secret used to verify API-server dispatches to POST /pr-execution.
# Required only when this agent image is deployed as a PR execution worker.
STHRIP_PR_EXECUTION_WORKER_SECRET=replace-with-pr-execution-worker-secret

# Set true for a dedicated PR-only worker container. In this mode the process
# does not require TENSOL_SIGN_KEY or TENSOL_SCAN_ID and /scan returns 503.
STHRIP_PR_EXECUTION_ONLY=false

# docker is the local/dev fallback. vercel-sandbox runs PR code in managed
# Vercel Firecracker microVMs and still switches branch-controlled commands to
# deny-all egress after dependency setup.
STHRIP_PR_EXECUTION_SANDBOX_PROVIDER=vercel-sandbox
STHRIP_PR_EXECUTION_DOCKER_IMAGE=node:22-bookworm
STHRIP_PR_EXECUTION_VERCEL_RUNTIME=node24
STHRIP_PR_EXECUTION_VERCEL_VCPUS=2

# Optional GitHub token for private repository fetches. The worker passes it to
# git fetch via transient GIT_CONFIG_* env and must not write it into .git/config.
STHRIP_PR_EXECUTION_GITHUB_TOKEN=replace-with-github-token

# Vercel Sandbox SDK auth. Prefer VERCEL_OIDC_TOKEN on Vercel-hosted workers;
# outside Vercel, use token + team/project ids scoped to the sandbox project.
VERCEL_OIDC_TOKEN=replace-with-vercel-oidc-token
VERCEL_TOKEN=replace-with-vercel-access-token
VERCEL_TEAM_ID=team_xxxxxxxxxxxxxxxxxxxxx
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxxxxxxxxxx
